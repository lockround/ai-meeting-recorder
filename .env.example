# Server (Node / Express)
OPENAI_API_KEY=sk-...
# If using Vercel AI Gateway for OpenAI, set the provider base URL:
# e.g. https://gateway.ai.cloudflare.com/v1/<account>/<gateway>/openai
OPENAI_BASE_URL=

# Optional model overrides
WHISPER_MODEL=whisper-1
SUMMARY_MODEL=gpt-4o-mini

# Server port
PORT=8787

# Mobile (Expo) - must be prefixed with EXPO_PUBLIC_ to expose to client
# For Android emulator, use http://10.0.2.2:8787
# For physical devices, use your LAN IP or tunnel URL
EXPO_PUBLIC_API_URL=http://10.0.2.2:8787

